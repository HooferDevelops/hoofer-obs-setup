                "url": "https://kelvinph.github.io/SpotiStream/overlay.html?theme=spotify&disc=200&bar=6&radius=0&blur=0&pad=0&outline=0&showstatus=0&shadow=0&accent=%23166aee&text=%23000000&muted=%23404040&panel=rgba%28236%2C233%2C216%2C1%29",
                "width": 850,
                "height": 200,
                "restart_when_active": false,
                "css": "* {\nbox-shadow: none !important;\n}\n\n.time {\nfont-size: 24px !important;\n}\n\n.title {\nfont-size: 28px !important;\n}\n\n.artist {\nfont-size: 24px !important;\n}\n\n/* XP-style progress track */\n.progress {\n  height: 24px !important;\n  padding: 2px !important;\n  background: #ffffff !important;\n  border: 1px solid #7f9db9 !important;\n  border-radius: 3px !important;\n  box-sizing: border-box !important;\n\n  /* subtle inset look */\n  box-shadow:\n    inset 1px 1px 0 #cfcfcf,\n    inset -1px -1px 0 #f3f3f3 !important;\n}\n\n/* fill element */\n.progress > * {\n  height: 100% !important;\n  border-radius: 1px !important;\n  box-sizing: border-box !important;\n\n  /* XP green chunks */\n  background:\n    repeating-linear-gradient(\n      to right,\n      #7ef07e 0px,\n      #7ef07e 8px,\n      #4fd44f 8px,\n      #4fd44f 10px,\n      transparent 10px,\n      transparent 12px\n    ) !important;\n\n  /* glossy top highlight */\n  box-shadow:\n    inset 0 1px 0 #caffca,\n    inset 0 -1px 0 #2ea62e !important;\n}\n\n@font-face {\n  font-family: TahomaBit;\n  src: url('https://cdn.jsdelivr.net/gh/HooferDevelops/hoofer-obs-setup@main/TahomaBit.ttf');\n}\n\n* {\n    font-family: TahomaBit !important;\n}\n\n.inner {\nmargin: 20px;\n}",
                "reroute_audio": false
            },
